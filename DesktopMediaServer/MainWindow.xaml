<Window x:Class="DesktopMediaServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopMediaServer" Height="340" Width="600">
    <Grid Margin="12">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="StartBtn" Width="120" Click="StartBtn_Click">Start Server</Button>
                <Button x:Name="StopBtn" Width="120" Margin="10,0,0,0"
                        Click="StopBtn_Click" IsEnabled="False">Stop Server</Button>
                <TextBlock Text="Port:" Margin="20,0,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="PortBox" Width="70" Text="3001" Margin="5,0,0,0"/>
                <TextBlock Text="Token:" Margin="20,0,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="TokenBox" Width="150" Text="changeme" Margin="5,0,0,0"/>
            </StackPanel>

            <TextBlock x:Name="StatusText" Margin="0,10,0,0" FontWeight="Bold"/>

            <TextBlock x:Name="TrackText" Margin="0,10,0,0" FontSize="16"/>
            <TextBlock x:Name="TimeText" Margin="0,5,0,0"/>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <Button Width="100" Click="Prev_Click">Prev</Button>
                <Button Width="120" Margin="10,0,0,0" Click="PlayPause_Click">Play/Pause</Button>
                <Button Width="100" Margin="10,0,0,0" Click="Next_Click">Next</Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>